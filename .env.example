# ╔═══════════════════════════════════════════════════════════════════╗
# ║  ConShell — Environment Configuration                           ║
# ║  Copy this file to .env and fill in your values                  ║
# ║  cp .env.example .env                                           ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ── Agent Settings ──────────────────────────────────────────────────
AGENT_NAME=conshell-agent
PORT=4200
DB_PATH=./state.db
LOG_LEVEL=info
DAILY_BUDGET_CENTS=5000

# ── LLM Providers ──────────────────────────────────────────────────
# Local Ollama (no key needed, just set URL)
OLLAMA_URL=http://localhost:11434

# Cloud Providers (uncomment and fill in as needed)
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# GEMINI_API_KEY=AIza-xxx
# NVIDIA_API_KEY=nvapi-xxx

# ── OAuth Configuration ────────────────────────────────────────────
# GitHub Copilot OAuth (Device Code Flow)
# Create an OAuth App at https://github.com/settings/developers
# GITHUB_OAUTH_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx

# Google Antigravity OAuth (Authorization Code + PKCE)
# Create credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4200/api/oauth/google/callback

# ── Security ───────────────────────────────────────────────────────
# Authentication mode: none | token | jwt
# WEB4_AUTH_MODE=none
# WEB4_AUTH_TOKEN=your-secret-token-here
# JWT_SECRET=your-jwt-secret-here

# ── Wallet (x402 Protocol) ─────────────────────────────────────────
# EVM wallet address for on-chain identity
# WALLET_ADDRESS=0x...

# ── External Services ──────────────────────────────────────────────
# CLIProxyAPI endpoint (if using remote proxy)
# CLIPROXYAPI_URL=http://localhost:3000
# CLIPROXYAPI_KEY=cpk-xxx
# CLIPROXYAPI_TIMEOUT_MS=120000

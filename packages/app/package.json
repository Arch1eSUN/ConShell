{
    "name": "conshell",
    "version": "0.1.0",
    "description": "ConShell — Sovereign AI Agent Runtime (Conway Automaton + Shell)",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "conshell": "dist/index.js"
    },
    "files": [
        "dist",
        "CONSTITUTION.md",
        "SOUL.md",
        "README.md"
    ],
    "keywords": [
        "ai-agent",
        "sovereign-ai",
        "conway-automaton",
        "conshell",
        "sovereign-ai",
        "x402",
        "digital-life"
    ],
    "scripts": {
        "build": "npx tsc --build",
        "dev": "tsx src/index.ts start",
        "start": "node dist/index.js start",
        "test": "npx vitest run",
        "test:watch": "vitest watch",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@conshell/core": "workspace:*",
        "@conshell/state": "workspace:*",
        "@conshell/policy": "workspace:*",
        "@conshell/skills": "workspace:*",
        "@conshell/inference": "workspace:*",
        "@conshell/memory": "workspace:*",
        "@conshell/soul": "workspace:*",
        "@conshell/runtime": "workspace:*",
        "@conshell/wallet": "workspace:*",
        "@conshell/selfmod": "workspace:*",
        "@conshell/security": "workspace:*",
        "@conshell/proxy": "workspace:*",
        "@conshell/cli": "workspace:*",
        "@conshell/x402": "workspace:*",
        "@inquirer/prompts": "^7.0.0",
        "chalk": "^5.3.0",
        "commander": "^13.0.0",
        "dotenv": "^16.4.0",
        "express": "^5.0.0",
        "open": "^10.1.0",
        "ora": "^8.1.0",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.0",
        "@types/express": "^5.0.0",
        "@types/ws": "^8.5.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0",
        "vitest": "^2.1.0"
    }
}
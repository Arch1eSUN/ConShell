{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "composite": true,
        "tsBuildInfoFile": "dist/.tsbuildinfo",
        "paths": {
            "@conshell/core": [
                "../core/src/index.ts"
            ]
        }
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "src/**/*.test.ts"
    ],
    "references": [
        {
            "path": "../core"
        }
    ]
}

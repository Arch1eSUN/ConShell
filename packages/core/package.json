{
    "name": "@web4-agent/core",
    "version": "0.1.0",
    "description": "Shared types, config, money primitives, logger, and error hierarchy for web4-agent",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc --build",
        "clean": "rm -rf dist *.tsbuildinfo",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "typescript": "^5.6.0",
        "vitest": "^2.1.0"
    }
}